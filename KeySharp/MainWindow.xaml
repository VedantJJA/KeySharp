<ui:FluentWindow x:Class="KeySharp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="KeySharp Pro" SizeToContent="Height" Width="340" 
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Native Theme Title Bar -->
        <ui:TitleBar Grid.Row="0" Title="KeySharp Pro" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,2">
            <StackPanel Margin="8">

                <!-- LIGHTING EFFECT CARD -->
                <ui:Card Margin="0,0,0,6" Padding="8">
                    <StackPanel>
                        <TextBlock Text="LIGHTING EFFECT" FontSize="9" FontWeight="Bold" Opacity="0.7" Margin="0,0,0,4"/>
                        <ComboBox x:Name="ModeSelector" SelectionChanged="ModeSelector_SelectionChanged" SelectedIndex="0" HorizontalAlignment="Stretch" FontSize="10" Padding="6,3" Focusable="False" IsTabStop="False">
                            <ComboBoxItem Content="Static (Solid)"/>
                            <ComboBoxItem Content="Rainbow Wave"/>
                            <ComboBoxItem Content="Fixed Color Ripple"/>
                            <ComboBoxItem Content="Per-Zone RGB Ripple"/>
                            <ComboBoxItem Content="Per-Key Random Ripple"/>
                            <ComboBoxItem Content="Map Test Mode"/>
                            <ComboBoxItem Content="Hardware Calibration"/>
                            <ComboBoxItem Content="Music Beat Sync"/>
                        </ComboBox>
                    </StackPanel>
                </ui:Card>

                <!-- GLOBAL BRIGHTNESS CARD -->
                <ui:Card Margin="0,0,0,6" Padding="8">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="GLOBAL BRIGHTNESS" FontSize="9" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="BrightnessVal" Text="100%" FontSize="9" FontWeight="SemiBold" Opacity="0.7" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <Slider x:Name="SliderBrightness" Minimum="0" Maximum="100" Value="100" ValueChanged="SliderBrightness_ValueChanged" Focusable="False" IsTabStop="False" Margin="0,0,0,2"/>
                    </StackPanel>
                </ui:Card>

                <!-- MUSIC SYNC PANEL -->
                <StackPanel x:Name="MusicPanel" Visibility="Collapsed">
                    <ui:Card Margin="0,0,0,6" Padding="8">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,4">
                                <TextBlock Text="BEAT SENSITIVITY" FontSize="9" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock x:Name="ThresholdVal" Text="50%" FontSize="9" FontWeight="SemiBold" Opacity="0.7" HorizontalAlignment="Right"/>
                            </DockPanel>
                            <Slider x:Name="SliderThreshold" Minimum="1" Maximum="100" Value="50" ValueChanged="SliderThreshold_ValueChanged" Focusable="False" IsTabStop="False" Margin="0,0,0,2"/>
                        </StackPanel>
                    </ui:Card>
                </StackPanel>

                <!-- RIPPLE SETTINGS -->
                <StackPanel x:Name="RipplePanel" Visibility="Collapsed">
                    <ui:Card Margin="0,0,0,6" Padding="8">
                        <StackPanel>
                            <TextBlock Text="RIPPLE SETTINGS" FontSize="9" FontWeight="Bold" Opacity="0.7" Margin="0,0,0,4"/>

                            <ui:ToggleSwitch Content="Enable Wall Bounce" x:Name="BounceToggle" Checked="Bounce_Changed" Unchecked="Bounce_Changed" Margin="0,0,0,6" FontSize="10" Focusable="False" IsTabStop="False"/>

                            <DockPanel Margin="0,0,0,2">
                                <TextBlock Text="DISTANCE" FontSize="9" FontWeight="SemiBold" Opacity="0.8"/>
                                <TextBlock x:Name="DistanceVal" Text="10" FontSize="9" Opacity="0.6" HorizontalAlignment="Right"/>
                            </DockPanel>
                            <Slider x:Name="SliderSteps" Minimum="1" Maximum="80" Value="10" ValueChanged="SliderSteps_ValueChanged" Focusable="False" IsTabStop="False" Margin="0,0,0,6"/>

                            <DockPanel Margin="0,0,0,2">
                                <TextBlock Text="WIDTH" FontSize="9" FontWeight="SemiBold" Opacity="0.8"/>
                                <TextBlock x:Name="WidthVal" Text="1" FontSize="9" Opacity="0.6" HorizontalAlignment="Right"/>
                            </DockPanel>
                            <Slider x:Name="SliderWidth" Minimum="1" Maximum="10" Value="1" ValueChanged="SliderWidth_ValueChanged" Focusable="False" IsTabStop="False" Margin="0,0,0,6"/>

                            <DockPanel Margin="0,0,0,2">
                                <TextBlock Text="SPEED" FontSize="9" FontWeight="SemiBold" Opacity="0.8"/>
                                <TextBlock x:Name="SpeedVal" Text="40ms" FontSize="9" Opacity="0.6" HorizontalAlignment="Right"/>
                            </DockPanel>
                            <Slider x:Name="SliderSpeed" Minimum="10" Maximum="200" Value="40" ValueChanged="SliderSpeed_ValueChanged" IsDirectionReversed="True" Focusable="False" IsTabStop="False" Margin="0,0,0,2"/>
                        </StackPanel>
                    </ui:Card>
                </StackPanel>

                <!-- COLOR MIXER -->
                <StackPanel x:Name="ColorPanel">
                    <ui:Card Margin="0,0,0,6" Padding="8">
                        <StackPanel>
                            <TextBlock Text="COLOR MIXER" FontSize="9" FontWeight="Bold" Opacity="0.7" Margin="0,0,0,6"/>

                            <TextBlock Text="RED" Foreground="#FF4444" FontSize="9" FontWeight="Bold" Margin="0,0,0,2"/>
                            <Slider x:Name="SliderR" Maximum="255" ValueChanged="ColorSlider_ValueChanged" Focusable="False" IsTabStop="False" Margin="0,0,0,6"/>

                            <TextBlock Text="GREEN" Foreground="#44FF44" FontSize="9" FontWeight="Bold" Margin="0,0,0,2"/>
                            <Slider x:Name="SliderG" Maximum="255" ValueChanged="ColorSlider_ValueChanged" Focusable="False" IsTabStop="False" Margin="0,0,0,6"/>

                            <TextBlock Text="BLUE" Foreground="#4444FF" FontSize="9" FontWeight="Bold" Margin="0,0,0,2"/>
                            <Slider x:Name="SliderB" Maximum="255" Value="255" ValueChanged="ColorSlider_ValueChanged" Focusable="False" IsTabStop="False" Margin="0,0,0,8"/>

                            <Border x:Name="ColorPreview" Height="24" Background="Blue" CornerRadius="4" BorderThickness="1" Opacity="0.9"/>
                        </StackPanel>
                    </ui:Card>
                </StackPanel>

                <!-- CALIBRATION -->
                <Border x:Name="CalibrationPanel" Visibility="Collapsed">
                    <ui:Card Margin="0,0,0,6" Padding="8">
                        <StackPanel>
                            <TextBlock Text="HARDWARE CALIBRATION" FontSize="9" FontWeight="Bold" Opacity="0.7" Margin="0,0,0,6"/>

                            <Border Background="#1A1A1A" CornerRadius="4" Padding="6" Margin="0,0,0,8">
                                <TextBlock x:Name="ZoneInfoText" Text="Zone: 0" Foreground="#00FFCC" FontFamily="Consolas" FontSize="10" HorizontalAlignment="Center"/>
                            </Border>

                            <UniformGrid Columns="2" Margin="0,0,0,8" Rows="1">
                                <ui:Button Content="PREV" Click="PrevZone_Click" Margin="0,0,4,0" HorizontalAlignment="Stretch" Padding="4" FontSize="10" Focusable="False" IsTabStop="False"/>
                                <ui:Button Content="NEXT" Click="NextZone_Click" Margin="4,0,0,0" HorizontalAlignment="Stretch" Padding="4" FontSize="10" Focusable="False" IsTabStop="False"/>
                            </UniformGrid>

                            <ui:Button Content="SAVE MAP" Click="SaveBtn_Click" Appearance="Primary" Margin="0,0,0,6" HorizontalAlignment="Stretch" Padding="4" FontSize="10" Focusable="False" IsTabStop="False"/>
                            <ui:Button Content="LOAD MAP" Click="LoadBtn_Click" HorizontalAlignment="Stretch" Padding="4" FontSize="10" Focusable="False" IsTabStop="False"/>
                        </StackPanel>
                    </ui:Card>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>