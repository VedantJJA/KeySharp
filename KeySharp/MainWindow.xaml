<ui:FluentWindow x:Class="KeySharp.MainWindow"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
            Title="KeySharp Pro" Height="480" Width="680" 
            WindowStartupLocation="CenterScreen"
            WindowBackdropType="Mica"
            ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Native Theme Title Bar -->
        <ui:TitleBar Grid.Row="0" Title="KeySharp Pro" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR TABS -->
            <ListBox x:Name="ModeListBox" Grid.Column="0" SelectionChanged="ModeListBox_SelectionChanged" SelectedIndex="0" Margin="8,0,0,8" Background="Transparent" BorderThickness="0">
                <ListBoxItem Padding="12,10" Margin="0,0,0,2">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="PaintBrush24" Margin="0,0,12,0"/>
                        <TextBlock Text="Static (Solid)" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Padding="12,10" Margin="0,0,0,2">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="WeatherSunny24" Margin="0,0,12,0"/>
                        <TextBlock Text="Rainbow Wave" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Padding="12,10" Margin="0,0,0,2">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Flash24" Margin="0,0,12,0"/>
                        <TextBlock Text="Fixed Color Ripple" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Padding="12,10" Margin="0,0,0,2">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Target24" Margin="0,0,12,0"/>
                        <TextBlock Text="Per-Zone RGB Ripple" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Padding="12,10" Margin="0,0,0,2">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Keyboard24" Margin="0,0,12,0"/>
                        <TextBlock Text="Per-Key Random Ripple" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Padding="12,10" Margin="0,0,0,2">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Beaker24" Margin="0,0,12,0"/>
                        <TextBlock Text="Map Test Mode" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Padding="12,10" Margin="0,0,0,2">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Wrench24" Margin="0,0,12,0"/>
                        <TextBlock Text="Hardware Calibration" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Padding="12,10" Margin="0,0,0,2">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Headphones24" Margin="0,0,12,0"/>
                        <TextBlock Text="Music Beat Sync" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </ListBoxItem>
            </ListBox>

            <!-- SETTINGS PANELS -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="8,0,12,8">
                <StackPanel Margin="8">

                    <TextBlock x:Name="ModeTitle" Text="STATIC (SOLID)" FontSize="16" FontWeight="Bold" Opacity="0.8" Margin="0,0,0,12"/>

                    <!-- GLOBAL BRIGHTNESS CARD -->
                    <ui:Card Margin="0,0,0,8" Padding="12">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock Text="GLOBAL BRIGHTNESS" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock x:Name="BrightnessVal" Text="100%" FontSize="11" FontWeight="SemiBold" Opacity="0.7" HorizontalAlignment="Right"/>
                            </DockPanel>
                            <Slider x:Name="SliderBrightness" Minimum="0" Maximum="100" Value="100" ValueChanged="SliderBrightness_ValueChanged" Focusable="False" IsTabStop="False" Margin="0,0,0,2"/>
                        </StackPanel>
                    </ui:Card>

                    <!-- MUSIC SYNC PANEL -->
                    <StackPanel x:Name="MusicPanel" Visibility="Collapsed">
                        <ui:Card Margin="0,0,0,8" Padding="12">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,6">
                                    <TextBlock Text="BEAT SENSITIVITY" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ThresholdVal" Text="50%" FontSize="11" FontWeight="SemiBold" Opacity="0.7" HorizontalAlignment="Right"/>
                                </DockPanel>
                                <Slider x:Name="SliderThreshold" Minimum="1" Maximum="100" Value="50" ValueChanged="SliderThreshold_ValueChanged" Focusable="False" IsTabStop="False" Margin="0,0,0,2"/>
                            </StackPanel>
                        </ui:Card>
                    </StackPanel>

                    <!-- RIPPLE SETTINGS -->
                    <StackPanel x:Name="RipplePanel" Visibility="Collapsed">
                        <ui:Card Margin="0,0,0,8" Padding="12">
                            <StackPanel>
                                <TextBlock Text="RIPPLE SETTINGS" FontSize="11" FontWeight="Bold" Opacity="0.7" Margin="0,0,0,8"/>

                                <ui:ToggleSwitch Content="Enable Wall Bounce" x:Name="BounceToggle" Checked="Bounce_Changed" Unchecked="Bounce_Changed" Margin="0,0,0,10" FontSize="12" Focusable="False" IsTabStop="False"/>

                                <DockPanel Margin="0,0,0,2">
                                    <TextBlock Text="DISTANCE" FontSize="11" FontWeight="SemiBold" Opacity="0.8"/>
                                    <TextBlock x:Name="DistanceVal" Text="5" FontSize="11" Opacity="0.6" HorizontalAlignment="Right"/>
                                </DockPanel>
                                <Slider x:Name="SliderSteps" Minimum="1" Maximum="80" Value="5" ValueChanged="SliderSteps_ValueChanged" Focusable="False" IsTabStop="False" Margin="0,0,0,10"/>

                                <DockPanel Margin="0,0,0,2">
                                    <TextBlock Text="WIDTH" FontSize="11" FontWeight="SemiBold" Opacity="0.8"/>
                                    <TextBlock x:Name="WidthVal" Text="1" FontSize="11" Opacity="0.6" HorizontalAlignment="Right"/>
                                </DockPanel>
                                <Slider x:Name="SliderWidth" Minimum="1" Maximum="10" Value="1" ValueChanged="SliderWidth_ValueChanged" Focusable="False" IsTabStop="False" Margin="0,0,0,10"/>

                                <DockPanel Margin="0,0,0,2">
                                    <TextBlock Text="SPEED" FontSize="11" FontWeight="SemiBold" Opacity="0.8"/>
                                    <TextBlock x:Name="SpeedVal" Text="20ms" FontSize="11" Opacity="0.6" HorizontalAlignment="Right"/>
                                </DockPanel>
                                <Slider x:Name="SliderSpeed" Minimum="10" Maximum="200" Value="20" ValueChanged="SliderSpeed_ValueChanged" IsDirectionReversed="True" Focusable="False" IsTabStop="False" Margin="0,0,0,4"/>
                            </StackPanel>
                        </ui:Card>
                    </StackPanel>

                    <!-- COLOR MIXER -->
                    <StackPanel x:Name="ColorPanel">
                        <ui:Card Margin="0,0,0,8" Padding="12">
                            <StackPanel>
                                <TextBlock Text="COLOR PRESETS" FontSize="11" FontWeight="Bold" Opacity="0.7" Margin="0,0,0,10"/>

                                <UniformGrid Columns="6" Margin="0,0,0,4" Height="24" HorizontalAlignment="Left">

                                    <!-- HOW TO CHANGE PRESETS -->
                                    <!-- 1. Change 'Background' to the visual hex code (e.g. #FF3B30). -->
                                    <!-- 2. Change 'Tag' to the actual hardware R,G,B numerical values (e.g. 255,59,48). -->

                                    <Border Background="#FF3B30" Tag="255,0,0" MouseLeftButtonDown="Preset_Click" Width="24" Height="24" Margin="0,0,8,0" CornerRadius="4" Cursor="Hand" ToolTip="Red"/>
                                    <Border Background="#34C759" Tag="52,199,89" MouseLeftButtonDown="Preset_Click" Width="24" Height="24" Margin="0,0,8,0" CornerRadius="4" Cursor="Hand" ToolTip="Green"/>
                                    <Border Background="#007AFF" Tag="0,30,255" MouseLeftButtonDown="Preset_Click" Width="24" Height="24" Margin="0,0,8,0" CornerRadius="4" Cursor="Hand" ToolTip="Blue"/>
                                    <Border Background="#AF52DE" Tag="201,0,255" MouseLeftButtonDown="Preset_Click" Width="24" Height="24" Margin="0,0,8,0" CornerRadius="4" Cursor="Hand" ToolTip="Purple"/>
                                    <Border Background="#FFCC00" Tag="255,204,0" MouseLeftButtonDown="Preset_Click" Width="24" Height="24" Margin="0,0,8,0" CornerRadius="4" Cursor="Hand" ToolTip="Yellow"/>

                                    <ToggleButton x:Name="CustomColorBtn" Content="+" Width="24" Height="24" Padding="0" ToolTip="Custom Color" Checked="CustomColor_Toggle" Unchecked="CustomColor_Toggle" Margin="0" BorderThickness="1" BorderBrush="#555555" Background="Transparent" Foreground="White"/>
                                </UniformGrid>

                                <!-- CUSTOM 2D COLOR PICKER -->
                                <StackPanel x:Name="CustomColorPanel" Visibility="Collapsed" Margin="0,12,0,0">
                                    <TextBlock Text="CUSTOM COLOR" FontSize="10" FontWeight="Bold" Opacity="0.6" Margin="0,0,0,10"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 2D Canvas -->
                                        <Border BorderBrush="#333" BorderThickness="1" CornerRadius="4" ClipToBounds="True" Width="130" Height="130" Margin="0,0,12,0">
                                            <Canvas x:Name="ColorCanvas" MouseLeftButtonDown="ColorCanvas_MouseDown" MouseMove="ColorCanvas_MouseMove" MouseLeftButtonUp="ColorCanvas_MouseUp" Background="Transparent" Cursor="Cross">
                                                <Rectangle x:Name="ColorCanvasBackground" Width="130" Height="130" Fill="#FF0000"/>
                                                <Rectangle Width="130" Height="130">
                                                    <Rectangle.Fill>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Rectangle.Fill>
                                                </Rectangle>
                                                <Rectangle Width="130" Height="130">
                                                    <Rectangle.Fill>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#00000000" Offset="0"/>
                                                            <GradientStop Color="#FF000000" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Rectangle.Fill>
                                                </Rectangle>

                                                <Ellipse x:Name="ColorThumb" Width="12" Height="12" Stroke="White" StrokeThickness="2" Fill="Transparent" Margin="-6,-6,0,0" IsHitTestVisible="False">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect ShadowDepth="1" BlurRadius="2" Opacity="0.5"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </Canvas>
                                        </Border>

                                        <!-- Hue Vertical Slider -->
                                        <Border Grid.Column="1" Height="130" CornerRadius="4" ClipToBounds="True" BorderBrush="#333" BorderThickness="1" Margin="0,0,12,0">
                                            <Grid>
                                                <Rectangle>
                                                    <Rectangle.Fill>
                                                        <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                                            <GradientStop Color="#FF0000" Offset="0.0"/>
                                                            <GradientStop Color="#FFFF00" Offset="0.167"/>
                                                            <GradientStop Color="#00FF00" Offset="0.333"/>
                                                            <GradientStop Color="#00FFFF" Offset="0.5"/>
                                                            <GradientStop Color="#0000FF" Offset="0.667"/>
                                                            <GradientStop Color="#FF00FF" Offset="0.833"/>
                                                            <GradientStop Color="#FF0000" Offset="1.0"/>
                                                        </LinearGradientBrush>
                                                    </Rectangle.Fill>
                                                </Rectangle>
                                                <Slider x:Name="HueSlider" Orientation="Vertical" Minimum="0" Maximum="360" Value="0" ValueChanged="HueSlider_ValueChanged" Opacity="0.01" />

                                                <Canvas IsHitTestVisible="False">
                                                    <Path x:Name="HueThumbVisual" Data="M 0,0 L 5,5 L 0,10 Z" Fill="White" Canvas.Right="-1"/>
                                                </Canvas>
                                            </Grid>
                                        </Border>

                                        <!-- HEX & RGB Texts -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Top">
                                            <TextBox x:Name="HexInput" Text="#FF0000" Margin="0,0,0,12" Padding="6,4" FontFamily="Consolas" TextChanged="HexInput_TextChanged"/>

                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="R" VerticalAlignment="Center" Margin="0,0,8,0" Width="12" Foreground="#FF4444" FontWeight="Bold"/>
                                                <TextBox x:Name="InputR" Grid.Column="1" Text="255" Padding="4,2" TextChanged="RgbInput_TextChanged"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="G" VerticalAlignment="Center" Margin="0,0,8,0" Width="12" Foreground="#44FF44" FontWeight="Bold"/>
                                                <TextBox x:Name="InputG" Grid.Column="1" Text="0" Padding="4,2" TextChanged="RgbInput_TextChanged"/>
                                            </Grid>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="B" VerticalAlignment="Center" Margin="0,0,8,0" Width="12" Foreground="#4444FF" FontWeight="Bold"/>
                                                <TextBox x:Name="InputB" Grid.Column="1" Text="0" Padding="4,2" TextChanged="RgbInput_TextChanged"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>

                                </StackPanel>
                            </StackPanel>
                        </ui:Card>
                    </StackPanel>

                    <!-- CALIBRATION -->
                    <Border x:Name="CalibrationPanel" Visibility="Collapsed">
                        <ui:Card Margin="0,0,0,8" Padding="12">
                            <StackPanel>
                                <TextBlock Text="HARDWARE CALIBRATION" FontSize="11" FontWeight="Bold" Opacity="0.7" Margin="0,0,0,8"/>

                                <Border Background="#1A1A1A" CornerRadius="4" Padding="10" Margin="0,0,0,12">
                                    <TextBlock x:Name="ZoneInfoText" Text="Zone: 0" Foreground="#00FFCC" FontFamily="Consolas" FontSize="12" HorizontalAlignment="Center"/>
                                </Border>

                                <UniformGrid Columns="2" Margin="0,0,0,12" Rows="1">
                                    <ui:Button Content="PREV" Click="PrevZone_Click" Margin="0,0,6,0" HorizontalAlignment="Stretch" Padding="6" FontSize="12" Focusable="False" IsTabStop="False"/>
                                    <ui:Button Content="NEXT" Click="NextZone_Click" Margin="6,0,0,0" HorizontalAlignment="Stretch" Padding="6" FontSize="12" Focusable="False" IsTabStop="False"/>
                                </UniformGrid>

                                <ui:Button Content="SAVE MAP" Click="SaveBtn_Click" Appearance="Primary" Margin="0,0,0,8" HorizontalAlignment="Stretch" Padding="6" FontSize="12" Focusable="False" IsTabStop="False"/>
                                <ui:Button Content="LOAD MAP" Click="LoadBtn_Click" HorizontalAlignment="Stretch" Padding="6" FontSize="12" Focusable="False" IsTabStop="False"/>
                            </StackPanel>
                        </ui:Card>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</ui:FluentWindow>